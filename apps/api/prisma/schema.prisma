generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model absence_justifications {
  id                       String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id                String               @db.Uuid
  student_id               String               @db.Uuid
  attendance_record_id     String?              @db.Uuid
  submitted_by_guardian_id String?              @db.Uuid
  reason                   String
  evidence_url             String?
  status                   justification_status @default(pending)
  reviewed_by              String?              @db.Uuid
  reviewed_at              DateTime?            @db.Timestamptz(6)
  review_note              String?
  created_at               DateTime             @default(now()) @db.Timestamptz(6)
  updated_at               DateTime             @default(now()) @db.Timestamptz(6)
  attendance_records       attendance_records?  @relation(fields: [attendance_record_id], references: [id], onUpdate: NoAction)
  users                    users?               @relation(fields: [reviewed_by], references: [id], onUpdate: NoAction)
  schools                  schools              @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students                 students             @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  guardians                guardians?           @relation(fields: [submitted_by_guardian_id], references: [id], onUpdate: NoAction)

  @@index([school_id, status, created_at(sort: Desc)], map: "absence_justifications_school_status_idx")
  @@index([student_id, created_at(sort: Desc)], map: "absence_justifications_student_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model academic_years {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id           String                @db.Uuid
  name                String
  starts_on           DateTime              @db.Date
  ends_on             DateTime              @db.Date
  is_active           Boolean               @default(false)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  schools             schools               @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  class_sections      class_sections[]
  student_enrollments student_enrollments[]

  @@unique([school_id, name])
}

model access_locations {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id         String               @db.Uuid
  name              String
  kind              access_location_kind @default(gate)
  description       String?
  is_active         Boolean              @default(true)
  created_at        DateTime             @default(now()) @db.Timestamptz(6)
  updated_at        DateTime             @default(now()) @db.Timestamptz(6)
  schools           schools              @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attendance_events attendance_events[]
  devices           devices[]
  incidents         incidents[]

  @@unique([school_id, name])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attendance_events {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id             String                  @db.Uuid
  attendance_record_id  String?                 @db.Uuid
  student_id            String?                 @db.Uuid
  event_time            DateTime                @default(now()) @db.Timestamptz(6)
  direction             attendance_direction    @default(entry)
  method                attendance_method
  result                attendance_event_result @default(accepted)
  status_after          attendance_status?
  location_id           String?                 @db.Uuid
  device_id             String?                 @db.Uuid
  recorded_by           String?                 @db.Uuid
  scanned_token_hash    String?
  biometric_match_score Decimal?                @db.Decimal(5, 2)
  failure_reason        String?
  notes                 String?
  metadata              Json                    @default("{}")
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  attendance_records    attendance_records?     @relation(fields: [attendance_record_id], references: [id], onUpdate: NoAction)
  devices               devices?                @relation(fields: [device_id], references: [id], onUpdate: NoAction)
  access_locations      access_locations?       @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  users                 users?                  @relation(fields: [recorded_by], references: [id], onUpdate: NoAction)
  schools               schools                 @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students              students?               @relation(fields: [student_id], references: [id], onUpdate: NoAction)
  incidents             incidents[]

  @@index([device_id, event_time(sort: Desc)], map: "attendance_events_device_time_idx")
  @@index([attendance_record_id], map: "attendance_events_record_idx")
  @@index([school_id, event_time(sort: Desc)], map: "attendance_events_school_time_idx")
  @@index([student_id, event_time(sort: Desc)], map: "attendance_events_student_time_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attendance_policies {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id        String          @db.Uuid
  section_id       String?         @db.Uuid
  name             String          @default("Default policy")
  days_of_week     Int[]           @default([1, 2, 3, 4, 5]) @db.SmallInt
  entry_starts_at  DateTime        @default(dbgenerated("'06:30:00'::time without time zone")) @db.Time(6)
  late_after       DateTime        @default(dbgenerated("'08:00:00'::time without time zone")) @db.Time(6)
  absence_after    DateTime        @default(dbgenerated("'09:00:00'::time without time zone")) @db.Time(6)
  exit_starts_at   DateTime?       @db.Time(6)
  exit_ends_at     DateTime?       @db.Time(6)
  notify_guardians Boolean         @default(true)
  metadata         Json            @default("{}")
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @default(now()) @db.Timestamptz(6)
  schools          schools         @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  class_sections   class_sections? @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model attendance_records {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id              String                   @db.Uuid
  student_id             String                   @db.Uuid
  class_section_id       String?                  @db.Uuid
  attendance_date        DateTime                 @db.Date
  status                 attendance_status        @default(pending)
  first_entry_at         DateTime?                @db.Timestamptz(6)
  last_exit_at           DateTime?                @db.Timestamptz(6)
  source                 attendance_method        @default(system)
  marked_by              String?                  @db.Uuid
  notes                  String?
  metadata               Json                     @default("{}")
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  absence_justifications absence_justifications[]
  attendance_events      attendance_events[]
  class_sections         class_sections?          @relation(fields: [class_section_id], references: [id], onUpdate: NoAction)
  users                  users?                   @relation(fields: [marked_by], references: [id], onUpdate: NoAction)
  schools                schools                  @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students               students                 @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  notifications          notifications[]

  @@unique([student_id, attendance_date])
  @@index([school_id, attendance_date], map: "attendance_records_school_date_idx")
  @@index([school_id, attendance_date, status], map: "attendance_records_school_status_idx")
  @@index([class_section_id, attendance_date], map: "attendance_records_section_date_idx")
  @@index([student_id, attendance_date(sort: Desc)], map: "attendance_records_student_date_idx")
}

model audit_logs {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id     String?  @db.Uuid
  actor_user_id String?  @db.Uuid
  action        String
  entity_type   String
  entity_id     String?  @db.Uuid
  metadata      Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  users         users?   @relation(fields: [actor_user_id], references: [id], onUpdate: NoAction)
  schools       schools? @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([actor_user_id, created_at(sort: Desc)], map: "audit_logs_actor_time_idx")
  @@index([school_id, created_at(sort: Desc)], map: "audit_logs_school_time_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model biometric_profiles {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id     String           @db.Uuid
  student_id    String           @db.Uuid
  provider      String
  template_ref  String
  template_hash String?
  quality_score Decimal?         @db.Decimal(5, 2)
  status        biometric_status @default(active)
  enrolled_by   String?          @db.Uuid
  enrolled_at   DateTime         @default(now()) @db.Timestamptz(6)
  revoked_at    DateTime?        @db.Timestamptz(6)
  metadata      Json             @default("{}")
  created_at    DateTime         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime         @default(now()) @db.Timestamptz(6)
  users         users?           @relation(fields: [enrolled_by], references: [id], onUpdate: NoAction)
  schools       schools          @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students      students         @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([student_id, provider, template_ref])
  @@index([student_id, status], map: "biometric_profiles_student_status_idx")
}

model class_sections {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id           String                @db.Uuid
  academic_year_id    String                @db.Uuid
  grade_level_id      String                @db.Uuid
  name                String                @default("A")
  display_name        String
  homeroom_teacher_id String?               @db.Uuid
  room                String?
  is_active           Boolean               @default(true)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  attendance_policies attendance_policies[]
  attendance_records  attendance_records[]
  academic_years      academic_years        @relation(fields: [academic_year_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  grade_levels        grade_levels          @relation(fields: [grade_level_id], references: [id], onUpdate: NoAction)
  staff_members       staff_members?        @relation(fields: [homeroom_teacher_id], references: [id], onUpdate: NoAction)
  schools             schools               @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_enrollments student_enrollments[]
  students            students[]

  @@unique([school_id, academic_year_id, grade_level_id, name])
  @@index([school_id, academic_year_id, is_active], map: "class_sections_school_year_idx")
}

model devices {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id         String              @db.Uuid
  location_id       String?             @db.Uuid
  assigned_staff_id String?             @db.Uuid
  name              String
  type              device_type
  identifier        String
  status            device_status       @default(active)
  last_seen_at      DateTime?           @db.Timestamptz(6)
  metadata          Json                @default("{}")
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  attendance_events attendance_events[]
  staff_members     staff_members?      @relation(fields: [assigned_staff_id], references: [id], onUpdate: NoAction)
  access_locations  access_locations?   @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  schools           schools             @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  incidents         incidents[]

  @@unique([school_id, identifier])
  @@index([location_id], map: "devices_location_idx")
  @@index([school_id, status], map: "devices_school_status_idx")
}

model grade_levels {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id      String           @db.Uuid
  code           String
  name           String
  stage          String
  sort_order     Int              @default(0)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  class_sections class_sections[]
  schools        schools          @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([school_id, code])
}

model guardians {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id              String                   @db.Uuid
  user_id                String?                  @unique @db.Uuid
