  notification_enabled   Boolean                  @default(true)
  metadata               Json                     @default("{}")
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  absence_justifications absence_justifications[]
  schools                schools                  @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  users?                   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  student_guardians      student_guardians[]

  @@unique([school_id, document_number])
  @@index([school_id, full_name], map: "guardians_school_name_idx")
}

model incidents {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id           String             @db.Uuid
  student_id          String?            @db.Uuid
  attendance_event_id String?            @db.Uuid
  device_id           String?            @db.Uuid
  location_id         String?            @db.Uuid
  type                incident_type      @default(other)
  severity            incident_severity  @default(medium)
  status              incident_status    @default(active)
  title               String
  description         String
  occurred_at         DateTime           @default(now()) @db.Timestamptz(6)
  resolved_at         DateTime?          @db.Timestamptz(6)
  resolved_by         String?            @db.Uuid
  resolution_note     String?
  metadata            Json               @default("{}")
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime           @default(now()) @db.Timestamptz(6)
  attendance_events   attendance_events? @relation(fields: [attendance_event_id], references: [id], onUpdate: NoAction)
  devices             devices?           @relation(fields: [device_id], references: [id], onUpdate: NoAction)
  access_locations    access_locations?  @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  users               users?             @relation(fields: [resolved_by], references: [id], onUpdate: NoAction)
  schools             schools            @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students            students?          @relation(fields: [student_id], references: [id], onUpdate: NoAction)
  notifications       notifications[]

  @@index([school_id, status, occurred_at(sort: Desc)], map: "incidents_school_status_idx")
  @@index([student_id, occurred_at(sort: Desc)], map: "incidents_student_idx")
}

model notification_preferences {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id        String               @db.Uuid
  user_id          String               @db.Uuid
  type             notification_type
  channel          notification_channel
  enabled          Boolean              @default(true)
  quiet_hours_from DateTime?            @db.Time(6)
  quiet_hours_to   DateTime?            @db.Time(6)
