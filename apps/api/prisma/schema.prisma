  schools          schools              @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, type, channel])
  @@index([school_id, user_id], map: "notification_preferences_school_user_idx")
}

model notifications {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_id            String               @db.Uuid
  recipient_user_id    String?              @db.Uuid
  student_id           String?              @db.Uuid
  attendance_record_id String?              @db.Uuid
  incident_id          String?              @db.Uuid
  type                 notification_type
  channel              notification_channel
  status               notification_status  @default(queued)
  title                String
  body                 String
  scheduled_for        DateTime             @default(now()) @db.Timestamptz(6)
  sent_at              DateTime?            @db.Timestamptz(6)
  delivered_at         DateTime?            @db.Timestamptz(6)
  read_at              DateTime?            @db.Timestamptz(6)
  delivery_attempts    Int                  @default(0)
  failure_reason       String?
  metadata             Json                 @default("{}")
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime             @default(now()) @db.Timestamptz(6)
  attendance_records   attendance_records?  @relation(fields: [attendance_record_id], references: [id], onUpdate: NoAction)
  incidents            incidents?           @relation(fields: [incident_id], references: [id], onUpdate: NoAction)
  users                users?               @relation(fields: [recipient_user_id], references: [id], onUpdate: NoAction)
  schools              schools              @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students             students?            @relation(fields: [student_id], references: [id], onUpdate: NoAction)

  @@index([recipient_user_id, status, created_at(sort: Desc)], map: "notifications_recipient_status_idx")
  @@index([school_id, status, scheduled_for], map: "notifications_school_status_idx")
  @@index([student_id, created_at(sort: Desc)], map: "notifications_student_idx")
}

model push_device_tokens {
